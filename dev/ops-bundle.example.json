{
  "team-uuids": [
    ["00000000-0000-0000-0000-000000000001", "Example Team"]
  ],
  "postgrest": {
    "tables": {
      "tasks": "eval_tasks",
      "task_versions": "eval_task_versions",
      "qa_feedback": "eval_task_qa_feedback",
      "profiles": "profiles",
      "task_projects": "task_projects",
      "environments": "environments",
      "task_project_targets": "task_project_targets",
      "verifiers": "verifiers",
      "verifier_versions": "verifier_versions",
      "team_members": "team_members"
    },
    "embeds": {
      "tasks_current_version": "eval_task_versions!eval_tasks_current_version_fk(id,prompt,env_key,version_no,created_at)"
    },
    "queries": {
      "tasks.select_with_current_version": {
        "table": "tasks",
        "select": "USE_EMBED_tasks_current_version"
      },
      "tasks.select_search": {
        "table": "tasks",
        "select": "id,key,created_by,team_id,env_key,task_project_target_id,task_lifecycle_status,created_at,eval_task_versions!eval_tasks_current_version_fk(id,prompt,env_key,version_no,created_at)"
      },
      "profiles.select_person": {
        "table": "profiles",
        "select": "id,full_name,email"
      },
      "qa_feedback.select_row": {
        "table": "qa_feedback",
        "select": "id,created_at,eval_task_id,is_positive_feedback,is_system_feedback,created_by,feedback_data,feedback_content"
      },
      "qa_feedback.select_row_scoped": {
        "table": "qa_feedback",
        "select": "id,created_at,eval_task_id,is_positive_feedback,is_system_feedback,created_by,feedback_data,feedback_content,eval_tasks!inner(id,team_id,env_key,task_project_target_id)"
      },
      "task_versions.select_history": {
        "table": "task_versions",
        "select": "id,task_id,version_no,created_at,prompt,env_key"
      },
      "task_versions.select_verifier_meta": {
        "table": "task_versions",
        "select": "verifier_id,metadata"
      },
      "task_project_targets.select_project_map": {
        "table": "task_project_targets",
        "select": "id,project_id"
      },
      "task_project_targets.select_ids": {
        "table": "task_project_targets",
        "select": "id"
      },
      "task_projects.select_bootstrap": {
        "table": "task_projects",
        "select": "id,name,description,status,project_key,created_at,team_id"
      },
      "environments.select_bootstrap": {
        "table": "environments",
        "select": "env_key,name"
      },
      "tasks.select_by_id": {
        "table": "tasks",
        "select": "USE_EMBED_tasks_current_version"
      },
      "verifiers.select_id_key": {
        "table": "verifiers",
        "select": "id,key"
      },
      "verifiers.select_id": {
        "table": "verifiers",
        "select": "id"
      },
      "tasks.select_verifier_lookup": {
        "table": "tasks",
        "select": "id,key,current_version_id,team_id"
      },
      "team_members.select_team": {
        "table": "team_members",
        "select": "team_id"
      },
      "verifier_versions.select_list": {
        "table": "verifier_versions",
        "select": "id,version,created_at"
      },
      "verifier_versions.select_source": {
        "table": "verifier_versions",
        "select": "id,version,created_at,display_src"
      }
    },
    "scoped_fields": {
      "qa_embed_team": "eval_tasks.team_id",
      "qa_embed_env": "eval_tasks.env_key",
      "qa_embed_target": "eval_tasks.task_project_target_id"
    }
  },
  "fleetWeb": {
    "disputes_list": "/disputes",
    "disputes_task": "/disputes/task-disputes",
    "task_events": "/tasks/task-events"
  }
}
